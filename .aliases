### Sean C. Johnson — Master Alias File
### sean@scj.net
#############################################

# Editor
alias nv='nvim'
alias vim='nvim'

# Navigation / listing
alias c='clear'
alias lls='ls -laFGhk'
alias ll='ls -lapFGhk | grep "/" && ls -lapFGhk | grep -v "/"'
alias size='du -h -d 1'
alias most='du -hsx * | sort -rh | head -10'

# Utilities
alias sha1='openssl sha1'
alias mkdir='mkdir -pv'
alias diff='colordiff'
alias mnt='mount | column -t'
alias j='jobs -l'
alias wget='wget -c'
alias search='mdfind --name'
alias ping='ping -c 5'

# Grep with color
alias grep='grep --color=auto'
alias egrep='egrep --color=auto'
alias fgrep='fgrep --color=auto'

# Process / CPU / memory (macOS-compatible)
alias psmem='ps auxr | sort -nrk 4 | head -10'
alias pscpu='ps auxr | sort -nrk 3 | head -10'
alias connections='lsof -n -P -i +c 15'

# Terraform
alias tfp='terraform fmt && terraform plan --out=plan.out'
alias tfa='terraform apply'
alias tfap='terraform apply "plan.out"'
alias tfs='terraform show'
alias tfv='terraform get -update && terraform validate'

# Suffix aliases (zsh only — open these filetypes in editor)
alias -s txt=nvim
alias -s md=nvim

# New shell script skeleton
alias newsh="touch ./new_script.sh && printf '#!/bin/bash\n\n' >> ./new_script.sh && chmod 755 ./new_script.sh"
