[sip]
media_encryption=none
default_proxy=-1
guess_hostname=1
contact="Sean C. Johnson" <sip:sean@192.168.15.232>
inc_timeout=15
use_info=0
use_rfc2833=0
use_ipv6=0
register_only_when_network_is_up=1

[sound]
playback_dev_id=AudioUnit: AirPlay
ringer_dev_id=AudioUnit: AirPlay
capture_dev_id=AudioUnit: Built-in Microphone
echocancellation=1
remote_ring=/opt/local/share/sounds/linphone/ringback.wav

[video]
size=cif
display=0
capture=0
show_local=0
self_view=0

[net]
adaptive_rate_control=1
firewall_policy=0
mtu=0

[GtkUi]
advanced_ui=1
lang=C

[rtp]
audio_rtp_port=7078
video_rtp_port=9078
audio_jitt_comp=60
video_jitt_comp=60
nortp_timeout=30

[audio_codec_0]
mime=speex
rate=32000
enabled=1

[audio_codec_1]
mime=speex
rate=16000
enabled=1

[audio_codec_2]
mime=speex
rate=8000
enabled=1

[audio_codec_3]
mime=PCMU
rate=8000
enabled=1

[audio_codec_4]
mime=PCMA
rate=8000
enabled=1

[audio_codec_5]
mime=L16
rate=44100
enabled=0

[audio_codec_6]
mime=L16
rate=44100
enabled=0

[audio_codec_7]
mime=G722
rate=8000
enabled=0

