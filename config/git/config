[user]
	name = Sean Johnson
	email = sean@scj.net

[core]
	excludesfile = ~/.gitignore_global
	autocrlf     = input
	editor       = nvim

[push]
	default       = current
	autoSetupRemote = true

[pull]
	rebase = true

[branch]
	autosetuprebase = always

[init]
	defaultBranch = main

[color]
	ui = auto

[diff]
	colorMoved = zebra

[commit]
	template = ~/.gitmessage

[alias]
	co      = checkout
	br      = branch
	ci      = commit
	st      = status
	lg      = log --oneline --graph --decorate --all
	unstage = reset HEAD --
	undo    = reset --soft HEAD~1
	aliases = config --get-regexp alias
